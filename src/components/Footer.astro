---
const year = new Date().getFullYear();
---

<footer>
  <p>© {year} Yazid Abu Sahal</p>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 4rem;
    width: var(--max-width);
    max-width: calc(100% - 2em);
    margin-left: auto;
    margin-right: auto;
  }

  p {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-muted);
    margin: 0;
  }
</style>