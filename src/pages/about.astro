---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="id">
  <head>
    <BaseHead title={`Tentang — ${SITE_TITLE}`} description="Tentang Yazid Abu Sahal" />
  </head>
  <body>
    <Header />
    <main>
      <div class="about">
        <h1>Tentang</h1>
        <p>
          Nama saya Yazid Abu Sahal. Mahasiswa informatika, tinggal di Sidoarjo.
        </p>
        <p>
          Blog ini saya buat sebagai tempat berpikir secara terbuka — tentang hal-hal yang saya baca, amati, dan pertanyakan. Tidak selalu selesai dan tidak selalu benar.
        </p>
        <p>
          Di luar nulis, saya tertarik pada teknologi, desain, dan memahami manusia
        </p>
        <div class="contact">
          <p>Bisa ditemukan di:</p>
          <ul>
            <li><a href="https://github.com/muhyazid" target="_blank">GitHub</a></li>
          </ul>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .about {
    padding-top: 3rem;
    max-width: 520px;
  }

  h1 {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  p {
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .contact {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .contact p {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 0.75rem;
  }

  ul {
    list-style: none;
    padding: 0;
  }

  ul li a {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>