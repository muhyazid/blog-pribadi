---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 5);
---

<!doctype html>
<html lang="id">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="intro">
        <h1>Yazid Abu Sahal</h1>
        <p class="bio">Mahasiswa informatika yang suka mikir, nulis, dan sesekali bingung sendiri. Blog ini tempat saya menaruh pikiran yang belum selesai.</p>
      </section>

      <section class="recent-posts">
        <h2>Tulisan terbaru</h2>
        <ul>
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`}>
                <span class="post-title">{post.data.title}</span>
                <span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
              </a>
            </li>
          ))}
        </ul>
        <a href="/blog" class="see-all">Semua tulisan →</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .intro {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 3rem;
  }

  .intro h1 {
    font-size: 1.8rem;
    margin-bottom: 0.8rem;
    letter-spacing: -0.02em;
  }

  .bio {
    color: var(--color-muted);
    font-size: 1rem;
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 0;
  }

  .recent-posts h2 {
    font-size: 0.85rem;
    font-family: var(--font-ui);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }

  ul li {
    border-bottom: 1px solid var(--color-border);
  }

  ul li a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1rem 0;
    gap: 1rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  ul li a:hover {
    opacity: 0.6;
    text-decoration: none;
  }

  .post-title {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-text);
  }

  .post-date {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-muted);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .see-all {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--color-muted);
    text-decoration: none;
  }

  .see-all:hover {
    color: var(--color-text);
    text-decoration: none;
  }
</style>